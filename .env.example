APP_NAME=Capital Group
ENVIRONMENT=local
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret
ADMIN_EMAIL=admin@capitalgroup.fr
ADMIN_PASSWORD=ChangeMe123!

# Local development defaults to SQLite. For Azure SQL, use:
# mssql+pyodbc://USER:PASSWORD@SERVER.database.windows.net:1433/DBNAME?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
DATABASE_URL=sqlite:///./capital_group.db

UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5
LOG_LEVEL=INFO
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
